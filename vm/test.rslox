var dia = "viernes";

switch (dia) {
  case "lunes": print "Buenos dias mundo";
  case "martes": print "Tengo algo de pereza";
  case "miercoles": print "Yupii hoy se mira anime";
  case "jueves": print "El cuerpo ya siente que es juernes";
  case "viernes": print "Hoy full bagancia";
  default: print "No lo se, no conosco este dia";
}